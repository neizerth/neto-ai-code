# Скопируйте в .env или используйте существующий файл:
#   08-task/example/gigachat_api/.env
# Переменные GIGACHAT_* загружаются оттуда автоматически (если файл есть).

GIGACHAT_CREDENTIALS=вставьте_сюда_ключ_авторизации
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_MODEL=GigaChat
# GIGACHAT_CA_BUNDLE_FILE=/путь/к/russian_trusted_root_ca_pem.crt
# GIGACHAT_VERIFY_SSL_CERTS=1
# DEMO_DEBUG=1

# JWT (обязательно для запуска API; сгенерируйте длинную случайную строку)
JWT_SECRET_KEY=замените_на_случайную_строку_минимум_32_символа
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
